# Archive root, not the /aets/.../rs subpath
DCM4CHEE_BASE_URL=http://localhost:8080/dcm4chee-arc

# Default AE title used for QIDO/WADO-style requests
NEXT_PUBLIC_DCM4CHEE_AET=DCM4CHEE

# Default queue shown on the monitoring page
NEXT_PUBLIC_DCM4CHEE_QUEUE=StgCmtSCU

# Branding
NEXT_PUBLIC_APP_TITLE=SQK Archive Console

# OHIF sibling runtime
OHIF_VIEWER_URL=http://localhost:3001
OHIF_PORT=3001
OHIF_APP_CONFIG=config/dicomweb-server.js
OHIF_PROXY_TARGET=/dicomweb
OHIF_ROUTER_BASENAME=/viewer
OHIF_PUBLIC_URL=/viewer/
OHIF_REPO_URL=https://github.com/OHIF/Viewers.git
OHIF_REPO_REF=master
NEXT_PUBLIC_OHIF_VIEWER_URL=/viewer/
NEXT_PUBLIC_OHIF_CONFIG_URL=/config/dicomweb-server.js
